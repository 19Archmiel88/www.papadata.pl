{
  "name": "papadata-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "start": "npm run start --workspace web",
    "lint": "npm run lint --workspace web",
    "typecheck": "npm run typecheck --workspace web && npm run build --workspace i18n --if-present"
  },
  "dependencies": {
    "lucide-react": "^0.441.0",
    "next": "^14.2.33"
  }
}
